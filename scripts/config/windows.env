@echo off
REM GEO 运营平台 - Windows 平台配置
REM 使用方法: call "%~dp0config\windows.env"

REM 项目根目录 (请根据实际路径修改)
set PROJECT_ROOT=C:\projects\q-geo

REM 前端目录
set FRONTEND_DIR=%PROJECT_ROOT%\front\ares_analysisnode

REM 后端目录
set BACKEND_DIR=%PROJECT_ROOT%\backend\ares_analysisterm

REM Tomcat 路径 (请根据实际安装路径修改)
set TOMCAT_HOME=C:\apache-tomcat-9.0.105

REM Node.js 版本
set NODE_VERSION=v12.16.1

REM Java 版本
set JAVA_VERSION=17

REM 端口配置
set BACKEND_PORT=8080
set FRONTEND_PORT=3000

REM JAVA_HOME (请根据实际安装路径修改)
set JAVA_HOME=C:\Program Files\Java\jdk-17

REM Maven 路径 (可选)
REM set MAVEN_HOME=C:\apache-maven-3.8.6
