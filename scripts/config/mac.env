#!/bin/bash
# GEO 运营平台 - Mac 平台配置
# 使用方法: source "$(dirname "$0")/../config/mac.env"

# 项目根目录
PROJECT_ROOT=/Users/apple/personal/q-geo

# 前端目录
FRONTEND_DIR=$PROJECT_ROOT/front/ares_analysisnode

# 后端目录
BACKEND_DIR=$PROJECT_ROOT/backend/ares_analysisterm

# Tomcat 路径 (Homebrew 安装)
TOMCAT_HOME=/opt/homebrew/Cellar/tomcat@9/9.0.105/libexec

# Node.js 版本
NODE_VERSION=v12.16.1

# Java 版本
JAVA_VERSION=17

# 端口配置
BACKEND_PORT=8080
FRONTEND_PORT=3000

# NVM 路径
NVM_PATH=~/.nvm/nvm.sh

# Maven 仓库路径 (可选)
# MAVEN_REPO=~/.m2/repository
